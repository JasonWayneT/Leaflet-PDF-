{
  "name": "leafletpdf",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start --workspace=@leafletpdf/electron-app",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "make": "npm run make --workspace=@leafletpdf/electron-app"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
